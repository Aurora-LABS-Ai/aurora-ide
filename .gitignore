*.sqlite
*.sqlite3
build
CLAUDE.md
# App data directories
.aurora/
*.aurora
target
# AI/ML tool directories — agent state, skill packs, IDE extensions,
# never part of source. These are all per-developer; checking them in
# means our git history catches every keystroke another tool makes.
.claude/
.claw/
.codex/
.cursor/
.zed/
.agents/
.refact/
.gitnexus/

# Agentic / IDE assistant instruction files that live at the repo
# root. They're personal config for whoever's machine the IDE is on
# — not project source.
AGENTS.md
CLAUDE.md
GEMINI.md
CODEX.md

# Local scratch / pasted snippets (not app source)
example.txt

# Junk dirs created by misconfigured tools writing to `undefined/...`
# (literal "undefined" string from `path.join(process.env.MISSING, ...)`).
# We've shipped at least one HuggingFace cache into here by accident.
/undefined/

# Agent task notes (lessons learned, todo lists) that live next to
# the code but aren't project source.
/tasks/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
nul
.gitnexus

# Third-party IDE / agentic tooling state (Refact.ai buddy, etc.) that
# lives inside the workspace but isn't part of the project source.
.refact/

# Loose screenshots dropped at the repo root while debugging — not source.
/image.png
/image-*.png
/screenshot.png
/screenshot-*.png
