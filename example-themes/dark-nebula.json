{
    "name": "Dark Nebula",
    "author": "Antigravity Gemini 3 Pro",
    "version": "1.1.0",
    "type": "dark",
    "colors": {
        "editor": {
            "background": "#0b0c15",
            "foreground": "#a9b1d6",
            "lineNumbers": "#3b4261",
            "lineNumbersActive": "#737aa2",
            "selection": "#3d59a144",
            "selectionHighlight": "#3d59a122",
            "cursor": "#c0caf5",
            "cursorLine": "#101014",
            "whitespace": "#3b4261",
            "indentGuide": "#1a1b26",
            "matchingBracket": "#7aa2f755",
            "wordHighlight": "#7aa2f733",
            "findMatch": "#e0af6855",
            "findMatchHighlight": "#e0af6833"
        },
        "sidebar": {
            "background": "#08080f",
            "foreground": "#787c99",
            "border": "#101014",
            "itemHover": "#3d59a111",
            "itemActive": "#3d59a133",
            "itemSelected": "#3d59a133",
            "sectionHeader": "#565f89"
        },
        "chat": {
            "background": "#0b0c15",
            "inputBackground": "#13141f",
            "inputBorder": "#1a1b26",
            "surface": "#0f1019",
            "surfaceBorder": "#1a1b26",
            "surfaceMuted": "#0a0b12",
            "usageLow": "#7dcfff",
            "usageMedium": "#e0af68",
            "usageHigh": "#f7768e",
            "userMessage": "#3d59a133",
            "assistantMessage": "#13141f",
            "thinkingBackground": "#1a1a2e",
            "thinkingBorder": "#3d59a1",
            "toolCallBackground": "#1a2e1a",
            "toolCallBorder": "#9ece6a",
            "codeBlock": "#13141f"
        },
        "terminal": {
            "background": "#0b0c15",
            "foreground": "#a9b1d6",
            "cursor": "#c0caf5",
            "selection": "#3d59a144",
            "black": "#15161e",
            "red": "#f7768e",
            "green": "#9ece6a",
            "yellow": "#e0af68",
            "blue": "#7aa2f7",
            "magenta": "#bb9af7",
            "cyan": "#7dcfff",
            "white": "#c0caf5",
            "brightBlack": "#414868",
            "brightRed": "#f7768e",
            "brightGreen": "#9ece6a",
            "brightYellow": "#e0af68",
            "brightBlue": "#7aa2f7",
            "brightMagenta": "#bb9af7",
            "brightCyan": "#7dcfff",
            "brightWhite": "#c0caf5"
        },
        "statusBar": {
            "background": "#08080f",
            "foreground": "#787c99",
            "border": "#101014",
            "itemHover": "#3d59a122"
        },
        "titleBar": {
            "background": "#08080f",
            "foreground": "#787c99",
            "border": "#101014",
            "buttonHover": "#3d59a122"
        },
        "common": {
            "primary": "#7aa2f7",
            "primaryHover": "#5d7dd4",
            "primaryForeground": "#ffffff",
            "secondary": "#24283b",
            "secondaryHover": "#343a52",
            "secondaryForeground": "#a9b1d6",
            "success": "#9ece6a",
            "successForeground": "#ffffff",
            "warning": "#e0af68",
            "warningForeground": "#000000",
            "error": "#f7768e",
            "errorForeground": "#ffffff",
            "info": "#7dcfff",
            "infoForeground": "#ffffff",
            "border": "#1a1b26",
            "borderHover": "#3d59a1",
            "shadow": "#00000066",
            "overlay": "#00000080",
            "scrollbar": "#3b4261",
            "scrollbarHover": "#565f89"
        }
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#565f89",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#c0caf5"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#bb9af7"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character",
                "constant.other"
            ],
            "settings": {
                "foreground": "#ff9e64"
            }
        },
        {
            "scope": [
                "string",
                "string punctuation.section.embedded source"
            ],
            "settings": {
                "foreground": "#9ece6a"
            }
        },
        {
            "scope": "entity.name.function",
            "settings": {
                "foreground": "#7aa2f7"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#f7768e"
            }
        }
    ]
}