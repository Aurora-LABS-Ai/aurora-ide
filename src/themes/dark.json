{
  "name": "Aurora Dark",
  "author": "Aurora Team",
  "version": "1.0.0",
  "type": "dark",
  "description": "Default dark theme for Aurora IDE",
  "colors": {
    "editor": {
      "background": "#0d0d0d",
      "foreground": "#e4e4e7",
      "lineNumbers": "#52525b",
      "lineNumbersActive": "#a1a1aa",
      "selection": "#10b98133",
      "selectionHighlight": "#10b98122",
      "cursor": "#10b981",
      "cursorLine": "#18181b",
      "whitespace": "#3f3f46",
      "indentGuide": "#27272a",
      "matchingBracket": "#10b98155",
      "wordHighlight": "#10b98133",
      "findMatch": "#fbbf2455",
      "findMatchHighlight": "#fbbf2433"
    },
    "sidebar": {
      "background": "#18181b",
      "foreground": "#a1a1aa",
      "border": "#27272a",
      "itemHover": "#27272a",
      "itemActive": "#3f3f46",
      "itemSelected": "#3f3f46",
      "sectionHeader": "#71717a"
    },
    "chat": {
      "background": "#09090b",
      "inputBackground": "#18181b",
      "inputBorder": "#27272a",
      "surface": "#18181b",
      "surfaceBorder": "#27272a",
      "surfaceMuted": "#27272a",
      "usageLow": "#22d3ee",
      "usageMedium": "#facc15",
      "usageHigh": "#ef4444",
      "userMessage": "#1e3a8a",
      "assistantMessage": "#18181b",
      "thinkingBackground": "#1e1b4b",
      "thinkingBorder": "#3730a3",
      "toolCallBackground": "#14532d",
      "toolCallBorder": "#166534",
      "codeBlock": "#18181b"
    },
    "terminal": {
      "background": "#0d0d0d",
      "foreground": "#e4e4e7",
      "cursor": "#10b981",
      "selection": "#10b98133",
      "black": "#000000",
      "red": "#ef4444",
      "green": "#22c55e",
      "yellow": "#eab308",
      "blue": "#3b82f6",
      "magenta": "#a855f7",
      "cyan": "#06b6d4",
      "white": "#f4f4f5",
      "brightBlack": "#52525b",
      "brightRed": "#f87171",
      "brightGreen": "#4ade80",
      "brightYellow": "#facc15",
      "brightBlue": "#60a5fa",
      "brightMagenta": "#c084fc",
      "brightCyan": "#22d3ee",
      "brightWhite": "#ffffff"
    },
    "statusBar": {
      "background": "#007acc",
      "foreground": "#ffffff",
      "border": "#007acc",
      "itemHover": "#ffffff20"
    },
    "titleBar": {
      "background": "#18181b",
      "foreground": "#a1a1aa",
      "border": "#27272a",
      "buttonHover": "#3f3f46"
    },
    "common": {
      "primary": "#10b981",
      "primaryHover": "#059669",
      "primaryForeground": "#ffffff",
      "secondary": "#27272a",
      "secondaryHover": "#3f3f46",
      "secondaryForeground": "#e4e4e7",
      "success": "#22c55e",
      "successForeground": "#ffffff",
      "warning": "#f59e0b",
      "warningForeground": "#000000",
      "error": "#ef4444",
      "errorForeground": "#ffffff",
      "info": "#3b82f6",
      "infoForeground": "#ffffff",
      "border": "#27272a",
      "borderHover": "#3f3f46",
      "shadow": "#00000066",
      "overlay": "#00000080",
      "scrollbar": "#3f3f46",
      "scrollbarHover": "#52525b",
      "muted": "#27272a",
      "mutedForeground": "#71717a",
      "accent": "#10b981",
      "accentForeground": "#ffffff",
      "accentMuted": "#10b98120",
      "destructive": "#ef4444",
      "destructiveForeground": "#ffffff",
      "diffAdded": "#22c55e",
      "diffAddedForeground": "#4ade80",
      "diffRemoved": "#ef4444",
      "diffRemovedForeground": "#f87171",
      "diffModified": "#f59e0b",
      "diffModifiedForeground": "#fbbf24",
      "statusActive": "#22c55e",
      "statusInactive": "#52525b",
      "statusError": "#ef4444",
      "statusWarning": "#f59e0b",
      "taskPending": "#52525b",
      "taskInProgress": "#3b82f6",
      "taskCompleted": "#22c55e",
      "taskCancelled": "#ef4444",
      "secureConnection": "#22c55e",
      "insecureConnection": "#f59e0b",
      "localConnection": "#3b82f6",
      "actionAnalyze": "#3b82f6",
      "actionDebug": "#ef4444",
      "actionGenerate": "#a855f7",
      "actionTest": "#22c55e",
      "checkpoint": "#f59e0b",
      "checkpointForeground": "#fbbf24"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b7280",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#34d399"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#60a5fa"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#e4e4e7"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#f472b6"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#94a3b8"
      }
    }
  ]
}