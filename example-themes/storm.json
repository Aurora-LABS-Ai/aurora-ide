{
    "name": "Storm",
    "author": "grok",
    "version": "1.0.0",
    "type": "dark",
    "colors": {
        "editor": {
            "background": "#0d1117",
            "foreground": "#c9d1d9",
            "lineNumbers": "#30363d",
            "lineNumbersActive": "#58a6ff",
            "selection": "#264f7844",
            "cursor": "#58a6ff",
            "cursorLine": "#161b22"
        },
        "sidebar": {
            "background": "#0a0c10",
            "foreground": "#8b949e",
            "border": "#21262d",
            "itemHover": "#21262d44",
            "itemActive": "#264f7844",
            "itemSelected": "#264f7844",
            "sectionHeader": "#6e7681"
        },
        "chat": {
            "background": "#0d1117",
            "inputBackground": "#161b22",
            "inputBorder": "#30363d",
            "userMessage": "#264f7844",
            "assistantMessage": "#161b22"
        },
        "terminal": {
            "background": "#0d1117",
            "foreground": "#c9d1d9"
        },
        "statusBar": {
            "background": "#0a0c10",
            "foreground": "#8b949e",
            "border": "#21262d"
        },
        "titleBar": {
            "background": "#0a0c10",
            "foreground": "#8b949e",
            "border": "#21262d"
        },
        "common": {
            "primary": "#58a6ff",
            "secondary": "#21262d",
            "success": "#56d364",
            "warning": "#d29922",
            "error": "#f85149",
            "info": "#79c0ff",
            "border": "#30363d"
        }
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#6e7681",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#c9d1d9"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#ff7b72"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character",
                "constant.other"
            ],
            "settings": {
                "foreground": "#d29922"
            }
        },
        {
            "scope": [
                "string",
                "string punctuation.section.embedded source"
            ],
            "settings": {
                "foreground": "#56d364"
            }
        },
        {
            "scope": "entity.name.function",
            "settings": {
                "foreground": "#58a6ff"
            }
        },
        {
            "scope": "entity.name.tag",
            "settings": {
                "foreground": "#f85149"
            }
        }
    ]
}
